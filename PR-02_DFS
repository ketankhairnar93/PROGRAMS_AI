graph = {
    'A': ['B', 'C'],
    'B': ['D'],
    'C': ['E'],
    'D': [],
    'E': []
}

def dfs(node, visited=set()):
    if node in visited: return
    visited.add(node)
    print(node, end=' ')
    for n in graph[node]:
        dfs(n, visited)
print("DFS Traversal starting from node 'A':")
dfs('A')
